<mvc:View
	controllerName="sap.f.sample.DynamicPageResponsiveAvatar.controller.DynamicPageResponsiveAvatar"
	xmlns="sap.m"
	xmlns:f="sap.f"
	xmlns:layout="sap.ui.layout"
	xmlns:mvc="sap.ui.core.mvc"
	height="100%">
	<f:DynamicPage id="dynamicPageId"
		showFooter="true">
		<f:title>
			<f:DynamicPageTitle>
				<f:breadcrumbs>
					<Breadcrumbs currentLocationText="Responsive Avatar Demo">
						<Link text="Home" press=".handleLink1Press"/>
						<Link text="Examples" press=".handleLink2Press"/>
					</Breadcrumbs>
				</f:breadcrumbs>

				<f:heading>
					<HBox>
						<Title text="Denise Smith" wrapping="true"/>
						<ObjectMarker type="Favorite" class="sapUiTinyMarginBegin"/>
					</HBox>
				</f:heading>

				<f:expandedContent>
					<Text text="Senior UI Developer"/>
				</f:expandedContent>

				<f:snappedContent>
					<FlexBox fitContainer="true" alignItems="Center">
						<Avatar id="snappedAvatar"
							src="./test-resources/sap/uxap/images/imageID_275314.png"
							class="sapUiTinyMarginEnd"/>
						<Text text="Senior UI Developer"/>
					</FlexBox>
				</f:snappedContent>

				<f:actions>
					<OverflowToolbarButton icon="sap-icon://edit" text="Edit" type="Emphasized" tooltip="Edit">
						<layoutData>
							<OverflowToolbarLayoutData priority="NeverOverflow"/>
						</layoutData>
					</OverflowToolbarButton>
					<Button text="Toggle Footer" press=".toggleFooter"/>
				</f:actions>
			</f:DynamicPageTitle>
		</f:title>

		<f:header>
			<f:DynamicPageHeader pinnable="true">
				<FlexBox wrap="Wrap" class="sapUiSmallMarginBottom">
					<Avatar id="headerAvatar"
						class="sapUiSmallMarginEnd"
						src="./test-resources/sap/uxap/images/imageID_275314.png"
						press=".handleAvatarPress"/>

					<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
						<Link text="+33 6 4512 5158"/>
						<Link text="DeniseSmith@sap.com"/>
					</layout:VerticalLayout>

					<layout:VerticalLayout class="sapUiSmallMarginBeginEnd">
						<Label text="San Jose, USA"/>
						<Label text="Resize the browser to see the Avatar adapt"/>
					</layout:VerticalLayout>
				</FlexBox>

				<MessageStrip
					text="The Avatar size changes automatically based on screen size: Phone (M), Tablet (L), Desktop/DesktopExtraLarge (XL). This is handled using the breakpointChanged event."
					type="Information"
					showIcon="true"
					class="sapUiTinyMarginTopBottom"/>
			</f:DynamicPageHeader>
		</f:header>

		<f:content>
			<VBox class="sapUiContentPadding">
				<!-- About Section -->
				<Title text="About" titleStyle="H2" class="sapUiMediumMarginBottom"/>
				<layout:VerticalLayout class="sapUiSmallMarginBottom">
					<Title text="Responsive Avatar Example" level="H3"/>
					<Text text="This sample demonstrates how to use the breakpointChanged event to make Avatar sizes responsive."/>
					<Text text="The DynamicPage fires the breakpointChanged event whenever its width changes and crosses a breakpoint."/>
					<Text text="The application can handle this event to adjust UI elements like Avatar sizes accordingly."/>
					<Text class="sapUiSmallMarginTop" text="Breakpoints:"/>
					<Text text="- Phone: less than 600px ? Avatar size M (4rem)"/>
					<Text text="- Tablet: 600px - 1024px ? Avatar size L (5rem)"/>
					<Text text="- Desktop: 1024px - 1439px ? Avatar size XL (7rem)"/>
					<Text text="- DesktopExtraLarge: 1440px and above ? Avatar size XL (7rem)"/>
				</layout:VerticalLayout>

				<!-- Implementation Section -->
				<Title text="Implementation" titleStyle="H2" class="sapUiMediumMarginTopBottom"/>
				<layout:VerticalLayout class="sapUiSmallMarginBottom">
					<Title text="How it Works" level="H3"/>
					<Text text="1. Attach to the breakpointChanged event in the controller's onInit method"/>
					<Text text="2. In the event handler, get the currentRange parameter (Phone/Tablet/Desktop/DesktopExtraLarge)"/>
					<Text text="3. Map the range to appropriate Avatar sizes using a switch statement"/>
					<Text text="4. Update the Avatar's displaySize property"/>
					<Text class="sapUiSmallMarginTop" text="The event provides two parameters:"/>
					<Text text="- currentRange: The media range name (Phone, Tablet, Desktop, or DesktopExtraLarge)"/>
					<Text text="- currentWidth: The current width of the control in pixels"/>
				</layout:VerticalLayout>

				<!-- Additional Content Section -->
				<Title text="Additional Content" titleStyle="H2" class="sapUiMediumMarginTopBottom"/>
				<layout:VerticalLayout>
					<Title text="Benefits" level="H3"/>
					<Text text="- Full application control over responsive behavior"/>
					<Text text="- Simple event-based API"/>
					<Text text="- Can be used for any responsive UI adjustments, not just Avatars"/>
					<Text text="- Works seamlessly with FlexibleColumnLayout and other container controls"/>
				</layout:VerticalLayout>
			</VBox>
		</f:content>

		<f:footer>
			<OverflowToolbar>
				<ToolbarSpacer/>
				<Button type="Accept" text="Accept"/>
				<Button type="Reject" text="Reject"/>
			</OverflowToolbar>
		</f:footer>
	</f:DynamicPage>
</mvc:View>
